ENV['VAGRANT_DEFAULT_PROVIDER'] = 'libvirt'
Vagrant.configure("2") do |config|
  # Debian 12 hafif olduğu için iyi bir tercih
  config.vm.box = "debian/bookworm64"

  # --- L2 PROVIDER AYARLARI (KVM/LIBVIRT) ---
  config.vm.provider :libvirt do |libvirt|
    libvirt.driver = "kvm"
    libvirt.cpu_mode = 'host-passthrough' # Intel iMac CPU özelliklerini L2'ye geçirir
    libvirt.nested = true                 # İç içe sanallaştırmayı aktif eder
    libvirt.nic_model_type = 'virtio'     # Ağ hızı için kritik
    libvirt.disk_bus = 'scsi'             # Disk hızı için kritik
    libvirt.graphics_type = 'none'        # L2'lerde arayüze gerek yok, RAM kazandırır
  end

  # --- SERVER (CONTROL PLANE) ---
  # Only one VM needed for Part 2 (Server mode with apps deployed)
  config.vm.define "aliS" do |s|
    s.vm.hostname = "aliS"
    s.vm.network "private_network", ip: "192.168.56.110", libvirt__forward_mode: "none"

    s.vm.provider :libvirt do |v|
      v.memory = 1024
      v.cpus = 1
    end
    s.vm.provision "shell", path: "scripts/server_setup.sh"
  end

  # --- HOST /etc/hosts OTOMATİK GÜNCELLEME ---
  # vagrant up sonrası Mac'in /etc/hosts dosyasına app1.com ve app2.com ekler
  config.trigger.after :up do |trigger|
    trigger.info = "Adding app1.com and app2.com to /etc/hosts..."
    trigger.run = {
      inline: <<-SHELL
        grep -q "app1.com" /etc/hosts || sudo sh -c 'echo "192.168.56.110 app1.com" >> /etc/hosts'
        grep -q "app2.com" /etc/hosts || sudo sh -c 'echo "192.168.56.110 app2.com" >> /etc/hosts'
        grep -q "app3.com" /etc/hosts || sudo sh -c 'echo "192.168.56.110 app3.com" >> /etc/hosts'
        grep -q "denden.com" /etc/hosts || sudo sh -c 'echo "192.168.56.110 denden.com" >> /etc/hosts'
        echo "Done: app1.com, app2.com, app3.com, denden.com added to /etc/hosts"
      SHELL
    }
  end
end
